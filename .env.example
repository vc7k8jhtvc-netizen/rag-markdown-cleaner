# API authentication
OPENAI_API_KEY=REPLACE_WITH_YOUR_API_KEY

# Example: https://example.com/v1
OPENAI_BASE_URL=https://example.com/v1

# Model name supported by your API provider
OPENAI_MODEL=REPLACE_WITH_MODEL_NAME

# ------------------------------------------------------------
# Optional model context budget
# ------------------------------------------------------------

# Total context capacity of the selected model.
# Set to 0 to disable local context checking.
OPENAI_CONTEXT_WINDOW=0

# Maximum output tokens sent to the API.
# Set to 0 to omit the token-limit parameter.
OPENAI_MAX_OUTPUT_TOKENS=0

# Use max_tokens for most OpenAI-compatible APIs.
# Some newer models require max_completion_tokens.
OPENAI_TOKEN_PARAMETER=max_tokens

# Reserved context space for estimation errors and message overhead.
OPENAI_SAFETY_MARGIN_TOKENS=1024
